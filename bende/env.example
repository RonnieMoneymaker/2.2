# Database
DATABASE_URL=./sqlite.db

# JWT Secret
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long_and_random

# Email Configuration
EMAIL_PROVIDER=smtp
# Voor SMTP (bijv. Gmail, Outlook, eigen mailserver)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Voor SendGrid (alternatief voor SMTP)
SENDGRID_API_KEY=your_sendgrid_api_key_here

# Email verzender
FROM_EMAIL=noreply@jouwwebshop.nl

# Google Ads API
GOOGLE_ADS_DEVELOPER_TOKEN=your_developer_token_here
GOOGLE_ADS_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=your_client_secret_here
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token_here
GOOGLE_ADS_CUSTOMER_ID=123-456-7890

# Meta/Facebook Ads API
META_ACCESS_TOKEN=your_meta_access_token_here
META_AD_ACCOUNT_ID=act_1234567890
META_APP_ID=your_app_id_here
META_APP_SECRET=your_app_secret_here

# DHL API
DHL_API_KEY=your_dhl_api_key_here
DHL_API_SECRET=your_dhl_api_secret_here
DHL_ACCOUNT_NUMBER=your_dhl_account_number
DHL_ENVIRONMENT=sandbox

# PayPal API (voor betalingen)
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here
PAYPAL_MODE=sandbox

# Stripe API (voor betalingen)
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Mollie API (Nederlandse betalingen)
MOLLIE_API_KEY=test_your_mollie_api_key_here

# Server Configuration
PORT=5000
NODE_ENV=development

# CORS Origins (voor productie)
CORS_ORIGIN=http://localhost:3000
